<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

<androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="80dp">

        <!-- Hero Section -->
        <LinearLayout
            android:id="@+id/heroSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_xxl"
            android:paddingBottom="@dimen/spacing_xl"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👶"
                android:textSize="64sp"
                 />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:fontFamily="sans-serif-black"
                android:text="Baby Monitor"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                 />

            <TextView
                android:id="@+id/tvTagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:fontFamily="sans-serif-medium"
                android:text="Stay connected with your little one"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                 />
        </LinearLayout>

        <!-- Main Action Cards -->
        <LinearLayout
            android:id="@+id/cardsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/heroSection">

            <!-- Baby Station Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBabyStation"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_margin="@dimen/spacing_sm"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                
                android:translationY="50dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                app:rippleColor="#40FFFFFF">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_card_baby">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginBottom="@dimen/spacing_md"
                            android:src="@drawable/ic_baby_station"
                            app:tint="@android:color/white" />

                        <TextView
                            android:id="@+id/tvBabyStationLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:text="Baby\nStation"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/text_size_lg"
                            android:textStyle="bold" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Parent Station Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardParentStation"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_margin="@dimen/spacing_sm"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                
                android:translationY="50dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                app:rippleColor="#40FFFFFF">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_card_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginBottom="@dimen/spacing_md"
                            android:src="@drawable/ic_parent_station"
                            app:tint="@android:color/white" />

                        <TextView
                            android:id="@+id/tvParentStationLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:text="Parent\nStation"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/text_size_lg"
                            android:textStyle="bold" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Pro Banner -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGoPro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginTop="@dimen/spacing_md"
            android:clickable="true"
            android:focusable="true"
            
            android:translationY="50dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardsContainer"
            app:rippleColor="#40FFFFFF">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pro_banner">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding">

                    <ImageView
                        android:layout_width="@dimen/icon_size_xl"
                        android:layout_height="@dimen/icon_size_xl"
                        android:layout_marginEnd="@dimen/spacing_md"
                        android:src="@drawable/ic_crown"
                        app:tint="@android:color/white" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvProTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="Upgrade to Pro"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/text_size_xl"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvProSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:fontFamily="sans-serif-medium"
                            android:text="Remove ads • Premium features"
                            android:textColor="#F5F5F5"
                            android:textSize="@dimen/text_size_sm" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textColor="@android:color/white"
                        android:textSize="32sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Support Section - Modern Cards -->
        <LinearLayout
            android:id="@+id/supportContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:alpha="0"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardGoPro">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnFeedback"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/elevation_sm"
                app:rippleColor="@color/primary_blue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_sm">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_feedback"
                        app:tint="@color/primary_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="Feedback"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnReport"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/elevation_sm"
                app:rippleColor="@color/accent_coral">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_sm">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_report"
                        app:tint="@color/accent_coral" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="Report"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnRate"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/elevation_sm"
                app:rippleColor="#FFD700">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_sm">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_star"
                        app:tint="#FFD700" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="Rate Us"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnAbout"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/elevation_sm"
                app:rippleColor="@color/info_blue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_sm">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/info_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="About"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Coffee Support - Premium Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnSupport"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginTop="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_xxl"
            android:clickable="true"
            android:focusable="true"
            android:alpha="0"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/corner_radius_lg"
            app:cardElevation="@dimen/elevation_md"
            app:rippleColor="#40FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/supportContainer">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_md">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:src="@drawable/ic_coffee_animated"
                    app:tint="@android:color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Buy me a Coffee"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/text_size_md"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>

<!-- AdView (Fixed at bottom, outside scroll view) -->
<com.google.android.gms.ads.AdView
    android:id="@+id/adView"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|center_horizontal"
    android:layout_marginBottom="@dimen/spacing_md"
    app:adSize="BANNER"
    app:adUnitId="ca-app-pub-3940256099942544/6300978111" />

</FrameLayout>
