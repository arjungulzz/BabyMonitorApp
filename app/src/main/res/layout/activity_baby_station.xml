<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.example.babymonitor.ui.RoiOverlayView
        android:id="@+id/roiOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Gradient Overlay for automatic text contrast -->
    <View
        android:id="@+id/gradientOverlay"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/gradient_overlay"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Bar Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Status Pill -->
        <LinearLayout
            android:id="@+id/layoutStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/transparent"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/ic_circle_indicator"
                app:tint="@color/success_green"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Initializing..."
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="normal" />
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:srcCompat="@drawable/ic_info"
                app:tint="@color/text_primary"
                app:backgroundTint="@color/surface_white"
                app:fabSize="mini"
                app:elevation="2dp" 
                app:borderWidth="0dp"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnCloseStation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:srcCompat="@drawable/ic_close"
                app:tint="@color/surface_white"
                app:backgroundTint="@color/error_red"
                app:fabSize="mini"
                app:elevation="2dp" 
                app:borderWidth="0dp"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Control Panel -->
    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingHorizontal="12dp"
        android:background="@drawable/bg_control_panel">

        <!-- Zoom Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            
            <ImageView
                android:id="@+id/btnZoomOut"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:src="@drawable/ic_zoom_out"
                app:tint="@android:color/white"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <SeekBar
                android:id="@+id/seekBarZoom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="16dp"
                android:max="100"
                android:progressTint="@android:color/white"
                android:thumbTint="@android:color/white"/>

            <ImageView
                android:id="@+id/btnZoomIn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:src="@drawable/ic_zoom_in"
                app:tint="@android:color/white"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <!-- Main Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:weightSum="4">




            <!-- Switch Cam -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnFlipCamera"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:srcCompat="@drawable/ic_flip_camera"
                    app:tint="@color/text_primary"
                    app:backgroundTint="@color/surface_white"
                    app:fabSize="mini" 
                    app:elevation="2dp"
                    app:borderWidth="0dp"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Flip"
                    android:textColor="#E6FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- Mic Toggle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnMicToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:srcCompat="@drawable/ic_mic_on"
                    app:tint="@color/text_primary"
                    app:backgroundTint="@color/surface_white"
                    app:fabSize="mini"
                    app:elevation="2dp"
                    app:borderWidth="0dp"/>

                <TextView
                    android:id="@+id/tvMicLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mic On"
                    android:textColor="#E6FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- Flash Toggle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnFlashToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:srcCompat="@drawable/ic_flash_off"
                    app:tint="@color/text_primary"
                    app:backgroundTint="@color/surface_white"
                    app:fabSize="mini"
                    app:elevation="2dp"
                    app:borderWidth="0dp"/>

                <TextView
                    android:id="@+id/tvFlashLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Flash Off"
                    android:textColor="#E6FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- Eco Mode -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnEcoMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:srcCompat="@drawable/ic_eco"
                    app:tint="@color/text_primary"
                    app:backgroundTint="@color/surface_white"
                    app:fabSize="mini"
                    app:elevation="2dp"
                    app:borderWidth="0dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Eco Mode"
                    android:textColor="#E6FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
            
        </LinearLayout>
    </LinearLayout>

    <!-- Eco Mode Countdown Overlay -->
    <TextView
        android:id="@+id/tvEcoCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_toast_dark"
        android:text="Dimming screen in 5 seconds...\nTap anywhere to wake"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:letterSpacing="0.02"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_vertical"
        android:drawableStart="@drawable/ic_eco"
        android:drawablePadding="12dp"
        android:drawableTint="@color/success_green"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/layoutControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp"
        app:layout_constrainedWidth="true"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:elevation="8dp"/>




    <!-- Black Overlay for Eco Mode -->
    <FrameLayout
        android:id="@+id/overlayEcoMode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_eco"
                app:tint="#66FFFFFF"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eco Mode On"
                android:textColor="#66FFFFFF"
                android:textSize="16sp"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap anywhere to wake"
                android:textColor="#33FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </FrameLayout>


    <!-- Permanent Vertical Pro Sidebar (Right Side) -->
    <LinearLayout
        android:id="@+id/proSidebar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_control_panel"
        android:paddingVertical="8dp"
        android:paddingHorizontal="4dp"
        android:layout_marginEnd="8dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutControls"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Pro Badge Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRO"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_pro_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:layout_marginBottom="12dp"/>

        <!-- Set Zone -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnProSetZone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:srcCompat="@drawable/ic_crop"
                app:tint="@color/text_primary"
                app:backgroundTint="@color/surface_white"
                app:fabSize="mini"
                app:elevation="2dp"
                app:borderWidth="0dp"/>

            <TextView
                android:id="@+id/tvSetZoneLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set Motion\nZone"
                android:gravity="center"
                android:textColor="#E6FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Motion Alerts -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnProMotion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:srcCompat="@drawable/ic_motion"
                app:tint="@color/text_primary"
                app:backgroundTint="@color/surface_white"
                app:fabSize="mini"
                app:elevation="2dp"
                app:borderWidth="0dp"/>

            <TextView
                android:id="@+id/tvMotionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motion\nAlerts"
                android:gravity="center"
                android:textColor="#E6FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Noise Alerts -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnProNoise"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:srcCompat="@drawable/ic_volume_up"
                app:tint="@color/text_primary"
                app:backgroundTint="@color/surface_white"
                app:fabSize="mini"
                app:elevation="2dp"
                app:borderWidth="0dp"/>

            <TextView
                android:id="@+id/tvNoiseLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Noise\nAlerts"
                android:gravity="center"
                android:textColor="#E6FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
