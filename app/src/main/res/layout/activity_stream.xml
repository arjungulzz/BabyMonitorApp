<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context=".StreamActivity">

    <!-- Video Stream -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Disconnect Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnDisconnect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_lg"
        android:contentDescription="Disconnect"
        app:backgroundTint="@color/error_red"
        app:elevation="@dimen/elevation_lg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_close"
        app:tint="@color/surface_white" />

    <!-- Error State -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/background_light"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xxl"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Error Icon -->
        <androidx.cardview.widget.CardView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:cardBackgroundColor="@color/error_light"
            app:cardCornerRadius="@dimen/corner_radius_xl"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_baby_station"
                app:tint="@color/error_red" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Connection Lost"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_xl"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center"
            android:text="The Baby Station is unreachable.\nPlease check your connection."
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_md" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_xl"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="@dimen/spacing_xxl"
            android:text="Go Back"
            android:textColor="@color/surface_white"
            android:textSize="@dimen/text_size_md"
            app:backgroundTint="@color/primary_blue"
            app:cornerRadius="@dimen/button_corner_radius" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
